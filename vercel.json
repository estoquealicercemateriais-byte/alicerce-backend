{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",
  "installCommand": "corepack pnpm@9.15.9 install --frozen-lockfile --ignore-scripts",
  "buildCommand": "corepack pnpm@9.15.9 --filter @workspace/whatsbot-dashboard build",
  "outputDirectory": "artifacts/whatsbot-dashboard/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
